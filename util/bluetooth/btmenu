#!/usr/bin/env python3
"""btmenu — gestor interactivo de Bluetooth (Cyberpunk Red)"""

import os
import re
import select
import subprocess
import sys
import termios
import threading
import tty
from time import sleep

# ── Colores ───────────────────────────────────────────────────────────────────
R   = '\033[38;2;255;0;60m'
Y   = '\033[38;2;252;238;10m'
C   = '\033[38;2;0;207;255m'
G   = '\033[38;2;255;204;204m'
B   = '\033[1m'
RST = '\033[0m'

HEADER = (
    f"{R}{B}"
    "  ██████╗ ████████╗██╗  ██╗\n"
    "  ██╔══██╗╚══██╔══╝██║  ██║\n"
    "  ██████╔╝   ██║   ███████║\n"
    "  ██╔══██╗   ██║   ██╔══██║\n"
    "  ██████╔╝   ██║   ██║  ██║\n"
    "  ╚═════╝    ╚═╝   ╚═╝  ╚═╝\n"
    f"{RST}"
)

SPIN      = ['⠋','⠙','⠹','⠸','⠼','⠴','⠦','⠧','⠇','⠏']
PAGE_SIZE = 10

# ── Helpers de terminal ───────────────────────────────────────────────────────

def clr():
    os.system('clear')

def cursor_hide():
    sys.stdout.write('\033[?25l'); sys.stdout.flush()

def cursor_show():
    sys.stdout.write('\033[?25h'); sys.stdout.flush()

def cursor_save():
    sys.stdout.write('\033[s'); sys.stdout.flush()

def cursor_restore():
    sys.stdout.write('\033[u'); sys.stdout.flush()

def erase_down():
    sys.stdout.write('\033[J'); sys.stdout.flush()

def getch(timeout=0.35):
    """Lee un carácter; devuelve None si no hay input en el timeout."""
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        r, _, _ = select.select([sys.stdin], [], [], timeout)
        if r:
            ch = sys.stdin.read(1)
            if ch == '\x1b':
                r2, _, _ = select.select([sys.stdin], [], [], 0.05)
                if r2:
                    try:
                        sys.stdin.read(2)
                    except Exception:
                        pass
            return ch
        return None
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)

def strip_ansi(s):
    return re.sub(r'\x1b\[[0-9;]*[mGKHFJA-Za-z]', '', s)

# ── Bluetooth helpers ─────────────────────────────────────────────────────────

def bt_run(*args, timeout=6):
    try:
        r = subprocess.run(
            ['bluetoothctl', '--', *args],
            capture_output=True, text=True, timeout=timeout
        )
        return (r.stdout + r.stderr).strip()
    except subprocess.TimeoutExpired:
        return ""

def bt_is_on():
    out = subprocess.run(['bluetoothctl', 'show'],
                         capture_output=True, text=True).stdout
    return 'Powered: yes' in out

def _parse_devices(raw):
    devs = {}
    for line in raw.splitlines():
        m = re.match(r'Device\s+([0-9A-Fa-f:]{17})\s+(.*)', line)
        if m:
            devs[m.group(1)] = m.group(2).strip()
    return devs

def all_devices():
    out = subprocess.run(['bluetoothctl', 'devices'],
                         capture_output=True, text=True).stdout
    return _parse_devices(out)

def connected_devices():
    out = subprocess.run(['bluetoothctl', 'devices', 'Connected'],
                         capture_output=True, text=True).stdout
    return _parse_devices(out)

def paired_devices():
    out = subprocess.run(['bluetoothctl', 'devices', 'Paired'],
                         capture_output=True, text=True).stdout
    return _parse_devices(out)

# ── Escaneo en background ─────────────────────────────────────────────────────

def start_scan(devs: dict, order: list, stop: threading.Event):
    def _worker():
        try:
            proc = subprocess.Popen(
                ['bluetoothctl'],
                stdin=subprocess.PIPE, stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT, text=True, bufsize=1
            )
            proc.stdin.write('agent on\ndefault-agent\nscan on\n')
            proc.stdin.flush()

            while not stop.is_set():
                r, _, _ = select.select([proc.stdout], [], [], 0.2)
                if not r:
                    continue
                line = proc.stdout.readline()
                if not line:
                    break
                clean = strip_ansi(line).strip()

                m = re.match(r'\[NEW\]\s+Device\s+([0-9A-Fa-f:]{17})\s+(.*)', clean)
                if m:
                    mac, name = m.group(1), m.group(2).strip()
                    if mac not in devs:
                        devs[mac] = name or mac
                        order.append(mac)

                m = re.match(r'\[CHG\]\s+Device\s+([0-9A-Fa-f:]{17})\s+Name:\s+(.*)', clean)
                if m:
                    mac, name = m.group(1), m.group(2).strip()
                    if mac in devs and name:
                        devs[mac] = name

            try:
                proc.stdin.write('scan off\n')
                proc.stdin.flush()
                proc.terminate()
                proc.wait(timeout=2)
            except Exception:
                pass
        except Exception:
            pass

    t = threading.Thread(target=_worker, daemon=True)
    t.start()
    return t

# ── Pantalla de acciones para un dispositivo seleccionado ─────────────────────

def device_action_screen(mac, name, is_paired, is_connected):
    """Muestra opciones según el estado del dispositivo. Retorna True si se debe
    volver al listado, False si se debe salir."""
    while True:
        clr()
        print(HEADER, end='')
        print(f"  {C}{B}DISPOSITIVO SELECCIONADO{RST}\n")
        print(f"  {Y}Nombre : {RST}{G}{B}{name}{RST}")
        print(f"  {Y}MAC    : {RST}{G}{mac}{RST}")

        # Estado
        parts = []
        if is_connected: parts.append(f"{C}● Conectado{RST}")
        if is_paired:    parts.append(f"{Y}★ Pareado{RST}")
        if not parts:    parts.append(f"{R}○ Sin parear{RST}")
        print(f"  {Y}Estado : {RST}{('  '.join(parts))}")

        print(f"\n  {R}{'─' * 42}{RST}")

        # Construir acciones disponibles según estado
        actions = {}

        if not is_paired:
            print(f"  {Y}[E]{RST}  Emparejar y conectar")
            actions['e'] = 'pair_connect'

        if is_paired and not is_connected:
            print(f"  {Y}[Enter]{RST}  Conectar")
            actions['\r'] = 'connect'
            actions['\n'] = 'connect'

        if is_connected:
            print(f"  {Y}[D]{RST}  Desconectar")
            actions['d'] = 'disconnect'

        if is_paired:
            print(f"  {Y}[U]{RST}  Desemparejar")
            actions['u'] = 'unpair'

        print(f"\n  {R}[Esc]{RST}  Volver al listado")
        print(f"\n  {R}> {RST}", end='', flush=True)

        # Esperar tecla
        key = None
        while key is None:
            key = getch(0.5)

        if key == '\x1b':
            return  # volver al listado

        action = actions.get(key.lower() if key else '')
        if action is None:
            continue

        clr(); print(HEADER, end='')

        if action == 'pair_connect':
            _do_connect(mac, name, already_paired=False)
            return

        elif action == 'connect':
            _do_connect(mac, name, already_paired=True)
            return

        elif action == 'disconnect':
            print(f"\n  {Y}Desconectando {C}{name}{RST}...")
            out = bt_run('disconnect', mac, timeout=8)
            if 'successful' in out.lower():
                print(f"  {C}✓ Desconectado.{RST}")
            else:
                print(f"  {G}{out}{RST}")
            sleep(1.5)
            is_connected = False
            # Vuelve al loop para mostrar las opciones actualizadas (puede desemparejar)

        elif action == 'unpair':
            print(f"\n  {Y}Desemparejando {C}{name}{RST}...")
            if is_connected:
                bt_run('disconnect', mac, timeout=5)
            out = bt_run('remove', mac, timeout=8)
            if 'removed' in out.lower():
                print(f"  {C}✓ Eliminado.{RST}")
            else:
                print(f"  {G}{out}{RST}")
            sleep(1.5)
            return

# ── Conexión interna ──────────────────────────────────────────────────────────

def _do_connect(mac, name, already_paired=False):
    print(f"\n  {Y}Conectando a {C}{name}{RST}  {G}({mac}){RST}...")

    if not already_paired:
        print(f"  {Y}Pareando...{RST}")
        out = bt_run('pair', mac, timeout=20)
        if 'Failed' in out:
            print(f"  {R}✗ Error al parear:{RST} {G}{out}{RST}")
            sleep(2); return
        bt_run('trust', mac)

    out = bt_run('connect', mac, timeout=12)
    if 'successful' in out.lower():
        print(f"  {C}✓ Conectado a {Y}{name}{RST}")
    else:
        print(f"  {R}✗ Error al conectar.{RST}")
        if out:
            print(f"  {G}{out}{RST}")
    sleep(2)

# ── Pantalla principal: listado + escaneo ─────────────────────────────────────

def main():
    if not bt_is_on():
        clr(); print(HEADER, end='')
        print(f"\n  {R}Bluetooth apagado.{RST}")
        print(f"  {G}Actívalo con:{RST} bluetoothctl power on")
        sleep(3); sys.exit(1)

    # Pre-poblar: pareados primero
    paired_macs    = set(paired_devices())
    connected_macs = set(connected_devices())

    devs  = {}
    order = []
    for mac, name in paired_devices().items():
        devs[mac] = name; order.append(mac)
    for mac, name in all_devices().items():
        if mac not in devs:
            devs[mac] = name; order.append(mac)

    stop = threading.Event()
    start_scan(devs, order, stop)

    clr(); print(HEADER, end='')
    print(f"  {C}{B}BLUETOOTH — SELECCIONA UN DISPOSITIVO{RST}")
    print(f"  {G}Escribe el número + {Y}Enter{G} · {Y}N{G}/{Y}P{G}=páginas · {Y}Esc{G}=salir{RST}\n")
    cursor_save()
    cursor_hide()

    page = 0
    buf  = ''
    si   = 0

    try:
        while True:
            snap_order = list(order)
            snap_devs  = dict(devs)
            total      = len(snap_order)

            total_pages = max(1, (total + PAGE_SIZE - 1) // PAGE_SIZE)
            page        = min(page, max(0, total_pages - 1))
            start_idx   = page * PAGE_SIZE
            page_macs   = snap_order[start_idx : start_idx + PAGE_SIZE]

            cursor_restore(); erase_down()

            spin = SPIN[si]; si = (si + 1) % len(SPIN)
            pg_info = f"  {G}│  Pág. {C}{page+1}{G}/{C}{total_pages}{RST}" if total_pages > 1 else ''
            if total:
                print(f"  {G}Encontrados: {C}{total}{RST}  {spin}{pg_info}\n")
            else:
                print(f"  {G}Buscando... {C}{spin}{RST}\n")

            for row in range(PAGE_SIZE):
                if row < len(page_macs):
                    mac  = page_macs[row]
                    num  = start_idx + row + 1
                    name = snap_devs.get(mac, mac)
                    tags = ''
                    if mac in connected_macs: tags += f" {C}●{RST}"
                    if mac in paired_macs:    tags += f" {Y}★{RST}"
                    hi    = buf and str(num).startswith(buf)
                    num_c = f"{Y}[{num:2d}]{RST}" if hi else f"{C}[{num:2d}]{RST}"
                    print(f"  {num_c}  {G}{mac}{RST}  {Y}{name:<26}{RST}{tags}")
                else:
                    print()

            print(f"\n  {R}{'─' * 46}{RST}")
            legend = f"  {C}●{RST}=conectado  {Y}★{RST}=pareado"
            if total_pages > 1:
                legend += f"  {Y}N{RST}=sig.  {Y}P{RST}=ant."
            print(legend)
            buf_disp = f"{Y}{buf}{RST}" if buf else ''
            print(f"\n  {R}>{RST} {buf_disp}\033[K", end='', flush=True)

            key = getch(0.35)
            if key is None:
                continue

            if key in ('\r', '\n'):
                if buf:
                    try:
                        n = int(buf)
                        if 1 <= n <= total:
                            mac  = snap_order[n - 1]
                            name = snap_devs.get(mac, mac)
                            stop.set()
                            cursor_show()
                            # Refrescar estado real antes de mostrar opciones
                            paired_macs    = set(paired_devices())
                            connected_macs = set(connected_devices())
                            device_action_screen(
                                mac, name,
                                is_paired    = mac in paired_macs,
                                is_connected = mac in connected_macs,
                            )
                            # Volver al listado: reiniciar escaneo
                            paired_macs    = set(paired_devices())
                            connected_macs = set(connected_devices())
                            devs  = {}; order = []
                            for m, nm in paired_devices().items():
                                devs[m] = nm; order.append(m)
                            for m, nm in all_devices().items():
                                if m not in devs:
                                    devs[m] = nm; order.append(m)
                            stop = threading.Event()
                            start_scan(devs, order, stop)
                            clr(); print(HEADER, end='')
                            print(f"  {C}{B}BLUETOOTH — SELECCIONA UN DISPOSITIVO{RST}")
                            print(f"  {G}Escribe el número + {Y}Enter{G} · {Y}N{G}/{Y}P{G}=páginas · {Y}Esc{G}=salir{RST}\n")
                            cursor_save()
                            cursor_hide()
                            page = 0
                    except ValueError:
                        pass
                    buf = ''

            elif key in ('\x7f', '\x08'):
                buf = buf[:-1]

            elif key.isdigit():
                buf += key

            elif key.lower() == 'n':
                page = min(page + 1, total_pages - 1); buf = ''

            elif key.lower() == 'p':
                page = max(page - 1, 0); buf = ''

            elif key == '\x1b':
                break

    except KeyboardInterrupt:
        pass
    finally:
        cursor_show()
        stop.set()

    clr()
    sys.exit(0)

if __name__ == '__main__':
    main()
