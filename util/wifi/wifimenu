#!/usr/bin/env python3
"""wifimenu — gestor interactivo de WiFi (Cyberpunk Red)"""

import getpass
import os
import re
import select
import subprocess
import sys
import termios
import threading
import tty
from time import sleep

# ── Colores ───────────────────────────────────────────────────────────────────
R   = '\033[38;2;255;0;60m'
Y   = '\033[38;2;252;238;10m'
C   = '\033[38;2;0;207;255m'
G   = '\033[38;2;255;204;204m'
B   = '\033[1m'
RST = '\033[0m'

HEADER = (
    f"{R}{B}"
    "  ██╗    ██╗██╗███████╗██╗\n"
    "  ██║    ██║██║██╔════╝██║\n"
    "  ██║ █╗ ██║██║█████╗  ██║\n"
    "  ██║███╗██║██║██╔══╝  ██║\n"
    "  ╚███╔███╔╝██║██║     ██║\n"
    "   ╚══╝╚══╝ ╚═╝╚═╝     ╚═╝\n"
    f"{RST}"
)

SPIN      = ['⠋','⠙','⠹','⠸','⠼','⠴','⠦','⠧','⠇','⠏']
PAGE_SIZE = 10

# ── Helpers de terminal ───────────────────────────────────────────────────────

def clr():
    os.system('clear')

def cursor_hide():
    sys.stdout.write('\033[?25l'); sys.stdout.flush()

def cursor_show():
    sys.stdout.write('\033[?25h'); sys.stdout.flush()

def cursor_save():
    sys.stdout.write('\033[s'); sys.stdout.flush()

def cursor_restore():
    sys.stdout.write('\033[u'); sys.stdout.flush()

def erase_down():
    sys.stdout.write('\033[J'); sys.stdout.flush()

def getch(timeout=0.35):
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        r, _, _ = select.select([sys.stdin], [], [], timeout)
        if r:
            ch = sys.stdin.read(1)
            if ch == '\x1b':
                r2, _, _ = select.select([sys.stdin], [], [], 0.05)
                if r2:
                    try:
                        sys.stdin.read(2)
                    except Exception:
                        pass
            return ch
        return None
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)

# ── WiFi helpers ──────────────────────────────────────────────────────────────

def nm(*args, timeout=8):
    try:
        r = subprocess.run(
            ['nmcli', *args],
            capture_output=True, text=True, timeout=timeout
        )
        return (r.stdout + r.stderr).strip()
    except subprocess.TimeoutExpired:
        return ""

def _split_terse(line):
    parts = re.split(r'(?<!\\):', line)
    return [p.replace('\\:', ':') for p in parts]

def wifi_device():
    out = nm('-t', '-f', 'DEVICE,TYPE,STATE', 'device')
    for line in out.splitlines():
        p = _split_terse(line)
        if len(p) >= 2 and p[1] == 'wifi':
            return p[0]
    return None

def current_connection():
    """Devuelve (ssid, ip) de la conexión WiFi activa, o (None, None)."""
    dev = wifi_device()
    if not dev:
        return None, None
    out = nm('-t', '-f', 'GENERAL.CONNECTION,IP4.ADDRESS', 'device', 'show', dev)
    ssid = ip = None
    for line in out.splitlines():
        if line.startswith('GENERAL.CONNECTION:'):
            val = line.split(':', 1)[1].strip()
            if val and val != '--':
                ssid = val
        if line.startswith('IP4.ADDRESS'):
            ip = line.split(':', 1)[1].strip()
    return ssid, ip

def saved_wifi():
    """Devuelve {name: uuid} de conexiones WiFi guardadas."""
    out = nm('-t', '-f', 'NAME,TYPE,UUID', 'connection', 'show')
    conns = {}
    for line in out.splitlines():
        p = _split_terse(line)
        if len(p) >= 3 and 'wireless' in p[1]:
            conns[p[0]] = p[2]
    return conns

def scan_networks():
    out = nm('-t', '-f', 'IN-USE,SSID,BSSID,SIGNAL,SECURITY',
             'device', 'wifi', 'list')
    nets = []
    seen_bssid = set()
    for line in out.splitlines():
        p = _split_terse(line)
        if len(p) < 5:
            continue
        in_use, ssid, bssid, signal, security = p[0], p[1], p[2], p[3], p[4]
        if not bssid or bssid == '--' or bssid in seen_bssid:
            continue
        seen_bssid.add(bssid)
        try:
            sig = int(signal)
        except ValueError:
            sig = 0
        nets.append({
            'ssid'    : ssid or '[oculta]',
            'bssid'   : bssid,
            'signal'  : sig,
            'security': security if security and security != '--' else '',
            'in_use'  : in_use.strip() == '*',
        })
    nets.sort(key=lambda x: x['signal'], reverse=True)
    return nets

def signal_bar(pct):
    pct = int(pct)
    n = min(4, pct // 25)
    filled = '█' * n
    empty  = '░' * (4 - n)
    if pct >= 70: color = C
    elif pct >= 40: color = Y
    else: color = R
    return f"{color}{filled}{G}{empty}{RST}"

# ── Escaneo en background ─────────────────────────────────────────────────────

def start_scan(nets: list, lock: threading.Lock, stop: threading.Event):
    def _worker():
        subprocess.run(['nmcli', 'device', 'wifi', 'rescan'],
                       capture_output=True, timeout=10)
        while not stop.is_set():
            fresh = scan_networks()
            with lock:
                nets.clear()
                nets.extend(fresh)
            stop.wait(2.0)

    t = threading.Thread(target=_worker, daemon=True)
    t.start()
    return t

# ── Pantalla de acciones para una red seleccionada ────────────────────────────

def network_action_screen(net, dev):
    """Muestra opciones según el estado de la red. Retorna al terminar."""
    ssid  = net['ssid']
    bssid = net['bssid']
    sec   = net['security']

    while True:
        # Refrescar estado en cada iteración
        saved       = saved_wifi()
        cur_ssid, ip = current_connection()
        is_connected = (ssid == cur_ssid)
        is_saved     = (ssid in saved)

        clr(); print(HEADER, end='')
        print(f"  {C}{B}RED SELECCIONADA{RST}\n")
        print(f"  {Y}SSID    : {RST}{G}{B}{ssid}{RST}")
        print(f"  {Y}BSSID   : {RST}{G}{bssid}{RST}")
        print(f"  {Y}Señal   : {RST}{signal_bar(net['signal'])}  {G}{net['signal']}%{RST}")
        print(f"  {Y}Segur.  : {RST}{G}{sec if sec else 'Abierta'}{RST}")

        parts = []
        if is_connected: parts.append(f"{C}● Conectado{RST}" + (f"  {G}{ip}{RST}" if ip else ''))
        if is_saved:     parts.append(f"{Y}★ Guardado{RST}")
        if not parts:    parts.append(f"{R}○ Nueva red{RST}")
        print(f"  {Y}Estado  : {RST}{('  '.join(parts))}")

        print(f"\n  {R}{'─' * 42}{RST}")

        actions = {}

        if not is_connected:
            print(f"  {Y}[Enter]{RST}  Conectar")
            actions['\r'] = 'connect'
            actions['\n'] = 'connect'

        if is_connected:
            print(f"  {Y}[D]{RST}  Desconectar")
            actions['d'] = 'disconnect'

        if is_saved:
            print(f"  {Y}[F]{RST}  Olvidar red")
            actions['f'] = 'forget'

        print(f"\n  {R}[Esc]{RST}  Volver al listado")
        print(f"\n  {R}> {RST}", end='', flush=True)

        key = None
        while key is None:
            key = getch(0.5)

        if key == '\x1b':
            return

        action = actions.get(key.lower() if key else '')
        if action is None:
            continue

        clr(); print(HEADER, end='')

        if action == 'connect':
            _do_connect_net(net, set(saved.keys()))
            return

        elif action == 'disconnect':
            print(f"\n  {Y}Desconectando de {C}{ssid}{RST}...")
            out = nm('device', 'disconnect', dev, timeout=8)
            if 'successfully' in out.lower() or 'desconectad' in out.lower():
                print(f"  {C}✓ Desconectado.{RST}")
            else:
                print(f"  {G}{out}{RST}")
            sleep(1.5)
            # Vuelve al loop para mostrar opciones actualizadas (puede olvidar)

        elif action == 'forget':
            print(f"\n  {Y}Olvidando {C}{ssid}{RST}...")
            if is_connected:
                nm('device', 'disconnect', dev, timeout=5)
            out = nm('connection', 'delete', saved[ssid], timeout=8)
            if 'successfully' in out.lower() or 'eliminad' in out.lower() or not out:
                print(f"  {C}✓ Red olvidada.{RST}")
            else:
                print(f"  {G}{out}{RST}")
            sleep(1.5)
            return

# ── Conexión interna ──────────────────────────────────────────────────────────

def _do_connect_net(net, saved_ssids=None):
    saved_ssids = saved_ssids or set()
    ssid  = net['ssid']
    bssid = net['bssid']
    sec   = net['security']

    print(f"\n  {Y}Conectando a {C}{ssid}{RST}  {G}({bssid}){RST}...")

    if ssid in saved_ssids:
        out = nm('connection', 'up', ssid, timeout=20)
    elif sec:
        try:
            pwd = getpass.getpass(f"  {Y}Contraseña: {RST}")
        except (KeyboardInterrupt, EOFError):
            print(f"\n  {R}Cancelado.{RST}"); return
        out = nm('device', 'wifi', 'connect', bssid, 'password', pwd, timeout=30)
    else:
        out = nm('device', 'wifi', 'connect', bssid, timeout=20)

    if 'successfully' in out.lower() or 'activad' in out.lower():
        _, ip = current_connection()
        print(f"  {C}✓ Conectado.{RST}" + (f"  {G}{ip}{RST}" if ip else ''))
    else:
        print(f"  {R}✗ Error al conectar.{RST}")
        if out:
            print(f"  {G}{out}{RST}")
    sleep(2)

# ── Pantalla principal: listado + escaneo ─────────────────────────────────────

def main():
    dev = wifi_device()
    if not dev:
        clr(); print(HEADER, end='')
        print(f"\n  {R}No se encontró interfaz WiFi.{RST}")
        sleep(3); sys.exit(1)

    def _launch_scan():
        nets = scan_networks()
        lock = threading.Lock()
        stop = threading.Event()
        start_scan(nets, lock, stop)
        return nets, lock, stop

    nets, lock, stop = _launch_scan()

    clr(); print(HEADER, end='')
    print(f"  {C}{B}WiFi — SELECCIONA UNA RED{RST}")
    print(f"  {G}Escribe el número + {Y}Enter{G} · {Y}N{G}/{Y}P{G}=páginas · {Y}Esc{G}=salir{RST}\n")
    cursor_save()
    cursor_hide()

    page     = 0
    buf      = ''
    si       = 0
    snapshot = []

    try:
        while True:
            saved_ssids = set(saved_wifi().keys())

            with lock:
                snapshot = sorted(nets, key=lambda x: x['signal'], reverse=True)

            total       = len(snapshot)
            total_pages = max(1, (total + PAGE_SIZE - 1) // PAGE_SIZE)
            page        = min(page, max(0, total_pages - 1))
            start_idx   = page * PAGE_SIZE
            page_nets   = snapshot[start_idx : start_idx + PAGE_SIZE]

            cursor_restore(); erase_down()

            spin = SPIN[si]; si = (si + 1) % len(SPIN)
            pg_info = f"  {G}│  Pág. {C}{page+1}{G}/{C}{total_pages}{RST}" if total_pages > 1 else ''
            if total:
                print(f"  {G}Encontradas: {C}{total}{RST}  {spin}{pg_info}\n")
            else:
                print(f"  {G}Buscando... {C}{spin}{RST}\n")

            for row in range(PAGE_SIZE):
                if row < len(page_nets):
                    net  = page_nets[row]
                    num  = start_idx + row + 1
                    bar  = signal_bar(net['signal'])
                    ssid = net['ssid']
                    sec  = f"{net['security']:<5}" if net['security'] else 'open '
                    sec_c = f"{G}{sec}{RST}" if net['security'] else f"{R}{sec}{RST}"
                    tags = ''
                    if net['in_use']:             tags += f" {C}●{RST}"
                    if ssid in saved_ssids:       tags += f" {Y}★{RST}"
                    hi    = buf and str(num).startswith(buf)
                    num_c = f"{Y}[{num:2d}]{RST}" if hi else f"{C}[{num:2d}]{RST}"
                    print(f"  {num_c} {bar} {Y}{ssid:<28}{RST} {sec_c}{tags}")
                else:
                    print()

            print(f"\n  {R}{'─' * 46}{RST}")
            legend = f"  {C}●{RST}=conectado  {Y}★{RST}=guardado"
            if total_pages > 1:
                legend += f"  {Y}N{RST}=sig.  {Y}P{RST}=ant."
            print(legend)
            buf_disp = f"{Y}{buf}{RST}" if buf else ''
            print(f"\n  {R}>{RST} {buf_disp}\033[K", end='', flush=True)

            key = getch(0.35)
            if key is None:
                continue

            if key in ('\r', '\n'):
                if buf:
                    try:
                        n = int(buf)
                        if 1 <= n <= total:
                            net = snapshot[n - 1]
                            stop.set()
                            cursor_show()
                            network_action_screen(net, dev)
                            # Volver al listado: reiniciar escaneo
                            nets, lock, stop = _launch_scan()
                            clr(); print(HEADER, end='')
                            print(f"  {C}{B}WiFi — SELECCIONA UNA RED{RST}")
                            print(f"  {G}Escribe el número + {Y}Enter{G} · {Y}N{G}/{Y}P{G}=páginas · {Y}Esc{G}=salir{RST}\n")
                            cursor_save()
                            cursor_hide()
                            page = 0
                    except ValueError:
                        pass
                    buf = ''

            elif key in ('\x7f', '\x08'):
                buf = buf[:-1]

            elif key.isdigit():
                buf += key

            elif key.lower() == 'n':
                page = min(page + 1, total_pages - 1); buf = ''

            elif key.lower() == 'p':
                page = max(page - 1, 0); buf = ''

            elif key == '\x1b':
                break

    except KeyboardInterrupt:
        pass
    finally:
        cursor_show()
        stop.set()

    clr()
    sys.exit(0)

if __name__ == '__main__':
    main()
